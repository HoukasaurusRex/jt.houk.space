{
  "name": "jt.houk.space",
  "version": "2.0.0",
  "description": "Personal blog for JT Houk",
  "scripts": {
    "dev": "vuepress dev content",
    "build": "vuepress build content",
    "fetch": "node --env-file=.env.defaults --experimental-strip-types src/fetch-content.ts",
    "new-entry": "node --env-file=.env.defaults --experimental-strip-types src/new-entry.ts",
    "new-journal-entry": "node --experimental-strip-types src/new-entry.ts journal",
    "format-journal": "node --env-file=.env.defaults --experimental-strip-types src/format-journal.ts",
    "lint": "eslint --quiet --fix",
    "lint:md": "markdownlint-cli2 --fix 'content/**/*.md'",
    "wrap:md": "node --experimental-strip-types src/wrap-markdown-lines.ts",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "pw:test": "node --env-file=.env.defaults node_modules/.bin/playwright test",
    "pw:update": "node --env-file=.env.defaults node_modules/.bin/playwright test --update-snapshots",
    "test": "yarn cy:run",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@giscus/vue": "^3.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.1",
    "@vuepress/bundler-vite": "^2.0.0-rc.26",
    "@vuepress/plugin-blog": "^2.0.0-rc.124",
    "@vuepress/plugin-pwa": "^2.0.0-rc.124",
    "@vuepress/plugin-search": "^2.0.0-rc.124",
    "@vuepress/plugin-seo": "^2.0.0-rc.124",
    "@vuepress/theme-default": "^2.0.0-rc.124",
    "fetch-to-markdown": "^1.3.3",
    "gsap": "^3.14.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vuepress": "^2.0.0-rc.26"
  },
  "devDependencies": {
    "@netlify/functions": "^5.1.2",
    "@playwright/test": "^1.58.2",
    "@types/cypress": "^1.1.6",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cypress": "^15.11.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.98.0",
    "serve": "^14.2.6",
    "stylelint": "^17.4.0",
    "typescript-eslint": "^8.57.0",
    "vue": "^3.5.29",
    "vue-eslint-parser": "^10.1.0"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoukasaurusRex/jt.houk.space.git"
  },
  "keywords": [
    "blog",
    "vuepress",
    "cms"
  ],
  "author": "JT Houk <jt@houk.space> (https://jt.houk.space/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/HoukasaurusRex/jt.houk.space/issues"
  },
  "homepage": "https://github.com/HoukasaurusRex/jt.houk.space#readme"
}
