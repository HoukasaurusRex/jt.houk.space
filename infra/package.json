{
  "name": "keila-cloud-run",
  "version": "1.0.0",
  "description": "CDKTF infrastructure for deploying Keila on Google Cloud Run",
  "main": "main.js",
  "scripts": {
    "get": "cdktf get",
    "build": "tsc --noEmit",
    "synth": "cdktf synth",
    "deploy": "cdktf deploy",
    "destroy": "cdktf destroy",
    "diff": "cdktf diff",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@cdktf/provider-google": "^14.0.0",
    "@cdktf/provider-random": "^11.0.0",
    "cdktf": "^0.21.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "target": "ES2018"
          }
        }
      ]
    }
  }
}
